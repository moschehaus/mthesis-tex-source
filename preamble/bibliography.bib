@article{teixeiraPhysicsOrographicGravity2014,
  title = {The Physics of Orographic Gravity Wave Drag},
  author = {Teixeira, Miguel A. C.},
  date = {2014-07-11},
  journaltitle = {Frontiers in Physics},
  shortjournal = {Front. Phys.},
  volume = {2},
  publisher = {Frontiers},
