@article{peltierEvolutionStabilityFiniteAmplitude1979,
  title = {The {{Evolution}} and {{Stability}} of {{Finite-Amplitude Mountain Waves}}. {{Part II}}: {{Surface Wave Drag}} and {{Severe Downslope Windstorms}}},
