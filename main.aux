\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Time evolution of the spurious velocity field for the stationary hydrostatic balance using the standard SPH formulation, vertical axis is logarithmic. For standard SPH, the maximum and root-mean-square velocities exhibit serious growth, sitting at approximately $\qty {10}{\metre \per \second } - \qty {15}{\metre \per \second }$ at $t < \qty {50}{\second }$ and diverging rapidly at $t \approx \qty {50}{\second }$. For In contrast, the corresponding well-balanced (WB) variant maintains these norms at machine epsilon throughout the simulation.}}{69}{figure.caption.120}\protected@file@percent }
\zref@newlabel{fig:STATIONARY-NORMS}{\default{4.3}\page{69}\title{Time evolution of the spurious velocity field for the stationary hydrostatic balance using the standard SPH formulation, vertical axis is logarithmic. For standard SPH, the maximum and root-mean-square velocities exhibit serious growth, sitting at approximately $\qty {10}{\metre \per \second } - \qty {15}{\metre \per \second }$ at $t < \qty {50}{\second }$ and diverging rapidly at $t \approx \qty {50}{\second }$. For In contrast, the corresponding well-balanced (WB) variant maintains these norms at machine epsilon throughout the simulation}\abspage{76}\zc@counter{figure}\thecounter{4.3}\zc@type{figure}\zc@cntval{3}\zc@pgval{69}\zc@enclval{{4}{0}}\zc@pgfmt{2}\anchor{figure.caption.120}}
\newlabel{fig:STATIONARY-NORMS}{{4.3}{69}{Time evolution of the spurious velocity field for the stationary hydrostatic balance using the standard SPH formulation, vertical axis is logarithmic. For standard SPH, the maximum and root-mean-square velocities exhibit serious growth, sitting at approximately $\qty {10}{\metre \per \second } - \qty {15}{\metre \per \second }$ at $t < \qty {50}{\second }$ and diverging rapidly at $t \approx \qty {50}{\second }$. For In contrast, the corresponding well-balanced (WB) variant maintains these norms at machine epsilon throughout the simulation}{figure.caption.120}{}}
